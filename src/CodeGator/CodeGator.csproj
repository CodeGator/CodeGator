<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>General framework elements used by other CodeGator solutions</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>packageDefaultIcon-128x128.png</PackageIcon>
    <PackageProjectUrl>https://github.com/CodeGator/CodeGator</PackageProjectUrl>
    <RepositoryUrl>https://github.com/CodeGator/CodeGator</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\packageDefaultIcon-128x128.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include="..\..\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CodeGator.Validations" Version="1.0.7" />
    <PackageReference Include="Nerdbank.GitVersioning" Version="3.10.44-alpha">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
